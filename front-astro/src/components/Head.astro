---
type Props = {
  titre: string;
  lienCanonique: string;
  noindex?: boolean;
  styles?: string[];
  extraJS?: string;
};
const { titre, lienCanonique, noindex, styles, extraJS }: Props = Astro.props;
---

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- {% for baliseMeta in layout.balisesMeta %} -->
  <!-- {% assign contenu = baliseMeta.contenu | replace: 'SITE_URL', site.url %} -->
  <!-- <meta property="{{baliseMeta.propriete}}" content="{{contenu}}" /> -->
  <!-- {% endfor %} -->
  {
    import.meta.env.GOOGLE_SEARCH_CONSOLE_VERIFICATION && (
      <meta name="google-site-verification" content="{import.meta.env.GOOGLE_SEARCH_CONSOLE_VERIFICATION}" />
    )
  }
  <title>{titre}</title>
  <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "messervices.cyber.gouv.fr",
      "url": "https://messervices.cyber.gouv.fr/"
    }
  </script>
  <link rel="canonical" href={lienCanonique} />
  <meta name="description" content="{{ site.data.meta-description[page.url] | escape }}" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="csp-nonce" content="%%NONCE%%" />
  <link rel="stylesheet" href="/assets/styles/dsfr.css" />
  <link rel="stylesheet" href="/assets/styles/site.css" />
  <link rel="stylesheet" href="/assets/styles/boutons.css" />
  <link rel="stylesheet" href="/assets/styles/fonts.css" />
  {styles?.map((style) => <link rel="stylesheet" href={style} />)}
  <link
    href={`https://lab-anssi-ui-kit-prod-s3-assets.cellar-c2.services.clever-cloud.com/${import.meta.env.PUBLIC_UI_KIT_VERSION}/dsfr-variables.css`}
    rel="stylesheet"
    nonce="%%NONCE%%"
  />
  <link
    href={`https://lab-anssi-ui-kit-prod-s3-assets.cellar-c2.services.clever-cloud.com/${import.meta.env.PUBLIC_UI_KIT_VERSION}/lab-anssi-theme.msc.css`}
    rel="stylesheet"
    nonce="%%NONCE%%"
  />
  {extraJS && <script src={extraJS} type="module" />}
  <!-- {% include composant-svelte.html id="composants-ui" %} -->
  {
    import.meta.env.MATOMO_ID && (
      <script
        is:inline
        type="module"
        src="/scripts/matomo.js"
        data-id-site-matomo={import.meta.env.MATOMO_ID}
        id="script-matomo"
      />
    )
  }
  {
    import.meta.env.MATOMO_URL_TAG_MANAGER && (
      <script
        is:inline
        type="module"
        src="/scripts/matomoTagManager.js"
        data-url-tag-manager-matomo={import.meta.env.MATOMO_URL_TAG_MANAGER}
        id="script-matomo-tag-manager"
      />
    )
  }
  {
    import.meta.env.SENTRY_DSN && (
      <script
        is:inline
        type="module"
        src="/lib-svelte/dist/assets/sentry.js"
        data-environnement={import.meta.env.SENTRY_ENVIRONNEMENT}
        data-dsn={import.meta.env.SENTRY_DSN}
        id="script-sentry"
      />
    )
  }
  <link rel="dns-prefetch" href="https://lab-anssi-ui-kit-prod-s3-assets.cellar-c2.services.clever-cloud.com" />
  <link
    rel="preconnect"
    href="https://lab-anssi-ui-kit-prod-s3-assets.cellar-c2.services.clever-cloud.com"
    crossorigin
  />
  <link
    rel="preload"
    href={`https://lab-anssi-ui-kit-prod-s3-assets.cellar-c2.services.clever-cloud.com/${import.meta.env.PUBLIC_UI_KIT_VERSION}/lab-anssi-ui-kit.iife.js`}
    as="script"
  />
  <script
    src={`https://lab-anssi-ui-kit-prod-s3-assets.cellar-c2.services.clever-cloud.com/${import.meta.env.PUBLIC_UI_KIT_VERSION}/lab-anssi-ui-kit.iife.js`}
    nonce="%%NONCE%%"
    defer></script>
</head>
