{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": false,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "vite.config.ts",
    "vite.config.ssr.ts",
    "./src/plateforme/plateforme.plugin.ts",
    "./src/utils/injecteNonce.plugin.ts",
    "rollupOptions.ts"
  ]
}
